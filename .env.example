# ═══════════════════════════════════════
#  Vinted Sniper v2.0 — Configuration
# ═══════════════════════════════════════

# ── Vinted Account (required for autobuy) ──
VINTED_EMAIL=
VINTED_PASSWORD=

# ── Countries to monitor (comma-separated) ──
VINTED_COUNTRIES=fr

# ── Session ──
SESSION_POOL_SIZE=3
MAX_REQUESTS_PER_SESSION=80

# ── Scraper ──
POLL_INTERVAL_MS=5000

# ── Proxy ──
PROXY_ENABLED=false
# Comma-separated list or path to file
PROXY_LIST=
PROXY_FILE=proxies.txt

# ── Autobuy ──
AUTOBUY_ENABLED=false
AUTOBUY_DRY_RUN=true

# ── Discord ──
DISCORD_WEBHOOK=

# ── Slack ──
SLACK_WEBHOOK=

# ── Telegram ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Email (SMTP) ──
SMTP_HOST=smtp.gmail.com
SMTP_USER=
SMTP_PASS=
EMAIL_TO=

# ── SMS (Twilio) ──
SMS_SID=
SMS_TOKEN=
SMS_FROM=
SMS_TO=

# ── Generic Webhook ──
WEBHOOK_URL=

# ── Dashboard ──
DASHBOARD_PORT=3000

# ── Logging ──
LOG_LEVEL=info
