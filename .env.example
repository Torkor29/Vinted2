# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_WEBHOOK_SECRET=random_secret_string
TELEGRAM_GROUP_ID=-1001234567890

# URLs
WEBAPP_URL=https://yourdomain.com/webapp
API_URL=https://yourdomain.com/api
WEBHOOK_URL=https://yourdomain.com/webhook

# Database
DATABASE_URL=postgresql://vinted:vinted@db:5432/vintedbot

# Redis
REDIS_URL=redis://redis:6379

# Proxies (comma-separated)
PROXY_LIST=http://user:pass@proxy1:port,http://user:pass@proxy2:port

# Vinted
VINTED_DOMAIN=www.vinted.fr

# Scan
DEFAULT_SCAN_INTERVAL=3
MAX_FILTERS_PER_USER=5
PEPITE_DEFAULT_THRESHOLD=0.30

# Logging
LOG_LEVEL=info
