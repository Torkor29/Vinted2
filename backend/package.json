{
  "name": "vinted-bot-backend",
  "version": "1.0.0",
  "description": "Vinted monitoring bot backend with Telegram integration",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && node -e \"require('fs').cpSync('src/db/migrations','dist/db/migrations',{recursive:true})\"",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "fastify": "^5.2.1",
    "@fastify/cors": "^10.0.2",
    "@fastify/compress": "^8.0.2",
    "grammy": "^1.35.0",
    "undici": "^7.3.0",
    "pg": "^8.13.1",
    "ioredis": "^5.4.2",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.24.2",
    "node-cron": "^3.0.3",
    "crypto-js": "^4.2.0"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "tsx": "^4.19.2",
    "@types/node": "^22.12.0",
    "@types/pg": "^8.11.11",
    "@types/node-cron": "^3.0.11",
    "@types/crypto-js": "^4.2.2"
  }
}
